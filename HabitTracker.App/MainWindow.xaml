<Window x:Class="HabitTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Habit Tracker" Height="400" Width="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Мои привычки" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox x:Name="HabitsListBox" Grid.Row="1" DisplayMemberPath="Name" SelectionMode="Single"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Добавить привычку" Click="AddHabit_Click" Padding="10,5" Margin="5"/>
            <Button Content="Отметить выполнение" Click="MarkDone_Click" Padding="10,5" Margin="5"/>
            <Button Content="Статистика" Click="ShowStats_Click" Padding="10,5" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>