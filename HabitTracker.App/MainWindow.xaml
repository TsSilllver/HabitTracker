<Window x:Class="HabitTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:HabitTracker.App.Converters"
        Title="Habit Tracker" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Window.Resources>
        <!-- Шаблон карточки привычки с цветной рамкой -->
        <DataTemplate x:Key="HabitCardTemplate">
            <Border Width="220" Height="220" Margin="10" CornerRadius="8" 
                    Background="{StaticResource CardBackgroundBrush}" 
                    BorderBrush="{Binding ColorHex, Converter={StaticResource StringToColorConverter}}" 
                    BorderThickness="2">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок и кнопка-меню (три точки) -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" 
                                   Foreground="{StaticResource ForegroundBrush}" TextWrapping="Wrap"/>
                        <Button Grid.Column="1" Content="⋯" Background="Transparent" 
                                Foreground="{StaticResource ForegroundBrush}" FontSize="18" 
                                Padding="5,0" Tag="{Binding Id}">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Отметить выполнение" Click="MarkMenuItem_Click"/>
                                    <MenuItem Header="Статистика" Click="StatsMenuItem_Click"/>
                                    <MenuItem Header="Удалить" Click="DeleteMenuItem_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>

                    <!-- Описание -->
                    <TextBlock Grid.Row="1" Text="{Binding Description}" Foreground="#AAAAAA" 
                               TextWrapping="Wrap" MaxHeight="40" Margin="0,5"/>

                    <!-- Цель -->
                    <TextBlock Grid.Row="2" Text="{Binding TargetSummary}" 
                               Foreground="{StaticResource AccentBrush}" FontSize="12" 
                               Margin="0,0,0,5"/>

                    <!-- Кубики дней (цветные) -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" 
                                HorizontalAlignment="Center" VerticalAlignment="Bottom">
                        <ItemsControl ItemsSource="{Binding LastSevenDaysCompletion}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="18" Height="18" Margin="2" CornerRadius="3" 
                                            Background="{Binding ., Converter={StaticResource CompletedToBackgroundConverter}}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель с одной вкладкой -->
        <Border Grid.Column="0" Background="#252525" CornerRadius="8" Margin="0,0,10,0">
            <TabControl x:Name="MainTabControl" TabStripPlacement="Left">
                <TabItem Header="Привычки"/>
            </TabControl>
        </Border>

        <!-- Правая часть -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Мои привычки" FontSize="24" FontWeight="Bold" 
                       Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,10"/>

            <ListBox x:Name="HabitsListBox" Grid.Row="1" 
                     ItemTemplate="{StaticResource HabitCardTemplate}" 
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>

            <!-- Полная панель кнопок -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Добавить" Click="AddHabit_Click" Padding="15,8" Margin="5"/>
                <Button Content="Отметить" Click="MarkDone_Click" Padding="15,8" Margin="5"/>
                <Button Content="Экспорт" Click="Export_Click" Padding="15,8" Margin="5"/>
                <Button Content="Импорт" Click="Import_Click" Padding="15,8" Margin="5"/>
                <Button Content="Синхр." Click="Sync_Click" Padding="15,8" Margin="5"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>