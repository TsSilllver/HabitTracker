<Window x:Class="HabitTracker.App.AddHabitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить привычку" Height="650" Width="450"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource ForegroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Название:" Foreground="{StaticResource ForegroundBrush}" Margin="0,5"/>
            <TextBox x:Name="NameTextBox" Background="#3A3A3A" Foreground="White" BorderThickness="0" Padding="5"/>

            <TextBlock Text="Описание:" Foreground="{StaticResource ForegroundBrush}" Margin="0,15,0,5"/>
            <TextBox x:Name="DescriptionTextBox" Background="#3A3A3A" Foreground="White" BorderThickness="0" Padding="5" Height="60" TextWrapping="Wrap"/>

            <TextBlock Text="Целевое значение:" Foreground="{StaticResource ForegroundBrush}" Margin="0,15,0,5"/>
            <TextBox x:Name="TargetTextBox" Background="#3A3A3A" Foreground="White" BorderThickness="0" Padding="5" Text="1"/>

            <TextBlock Text="Единицы измерения:" Foreground="{StaticResource ForegroundBrush}" Margin="0,15,0,5"/>
            <TextBox x:Name="UnitTextBox" Background="#3A3A3A" Foreground="White" BorderThickness="0" Padding="5" Text="раз"/>

            <TextBlock Text="Цвет:" Foreground="{StaticResource ForegroundBrush}" Margin="0,15,0,5"/>
            <ComboBox x:Name="ColorCombo" Background="#3A3A3A" Foreground="White" BorderThickness="0" Padding="5" SelectedIndex="0">
                <ComboBoxItem Tag="#1CA9C9" Content="Голубой" Background="#1CA9C9" Foreground="White"/>
                <ComboBoxItem Tag="#FF6B6B" Content="Нежно-красный" Background="#FF6B6B" Foreground="White"/>
                <ComboBoxItem Tag="#FFB347" Content="Оранжевый" Background="#FFB347" Foreground="White"/>
                <ComboBoxItem Tag="#4CAF50" Content="Зелёный" Background="#4CAF50" Foreground="White"/>
                <ComboBoxItem Tag="#9C27B0" Content="Фиолетовый" Background="#9C27B0" Foreground="White"/>
            </ComboBox>

            <TextBlock Text="Тип привычки:" Foreground="{StaticResource ForegroundBrush}" Margin="0,15,0,5"/>
            <RadioButton x:Name="DailyRadio" Content="Ежедневная (все дни)" GroupName="HabitType" IsChecked="True" Foreground="{StaticResource ForegroundBrush}" Margin="5" Checked="DailyRadio_Checked"/>
            <RadioButton x:Name="WeeklyRadio" Content="Еженедельная (выберите дни)" GroupName="HabitType" Foreground="{StaticResource ForegroundBrush}" Margin="5" Checked="WeeklyRadio_Checked"/>

            <Border Margin="0,10,0,0" Padding="10" Background="#3A3A3A" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Дни недели:" Foreground="{StaticResource ForegroundBrush}"/>
                    <WrapPanel Margin="0,5">
                        <CheckBox x:Name="MonCheck" Content="Пн" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,10,0"/>
                        <CheckBox x:Name="TueCheck" Content="Вт" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,10,0"/>
                        <CheckBox x:Name="WedCheck" Content="Ср" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,10,0"/>
                        <CheckBox x:Name="ThuCheck" Content="Чт" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,10,0"/>
                        <CheckBox x:Name="FriCheck" Content="Пт" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,10,0"/>
                        <CheckBox x:Name="SatCheck" Content="Сб" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,10,0"/>
                        <CheckBox x:Name="SunCheck" Content="Вс" Foreground="{StaticResource ForegroundBrush}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Button Content="Сохранить" Click="SaveButton_Click" Background="{StaticResource AccentBrush}" Foreground="White" Margin="0,20" Padding="10,5" Height="40"/>
        </StackPanel>
    </ScrollViewer>
</Window>