<Window x:Class="HabitTracker.App.AddHabitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить привычку" Height="400" Width="400">
    <StackPanel Margin="10">
        <TextBlock Text="Название:" Margin="0,5"/>
        <TextBox x:Name="NameTextBox"/>

        <TextBlock Text="Описание:" Margin="0,10,0,5"/>
        <TextBox x:Name="DescriptionTextBox" Height="60" TextWrapping="Wrap"/>

        <TextBlock Text="Целевое значение:" Margin="0,10,0,5"/>
        <TextBox x:Name="TargetTextBox" Text="1"/>

        <TextBlock Text="Единицы измерения:" Margin="0,10,0,5"/>
        <TextBox x:Name="UnitTextBox" Text="раз"/>

        <TextBlock Text="Расписание (дни недели):" Margin="0,10,0,5"/>
        <WrapPanel>
            <CheckBox x:Name="MonCheck" Content="Пн" Margin="0,0,5,0"/>
            <CheckBox x:Name="TueCheck" Content="Вт" Margin="0,0,5,0"/>
            <CheckBox x:Name="WedCheck" Content="Ср" Margin="0,0,5,0"/>
            <CheckBox x:Name="ThuCheck" Content="Чт" Margin="0,0,5,0"/>
            <CheckBox x:Name="FriCheck" Content="Пт" Margin="0,0,5,0"/>
            <CheckBox x:Name="SatCheck" Content="Сб" Margin="0,0,5,0"/>
            <CheckBox x:Name="SunCheck" Content="Вс" Margin="0,0,5,0"/>
        </WrapPanel>

        <Button Content="Сохранить" Click="SaveButton_Click" Margin="0,20" Padding="10,5"/>
    </StackPanel>
</Window>
