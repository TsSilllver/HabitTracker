<Window x:Class="HabitTracker.App.MarkDoneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отметить выполнение" Height="300" Width="300">
    <StackPanel Margin="10">
        <TextBlock Text="Привычка:" FontWeight="Bold"/>
        <TextBlock x:Name="HabitNameText" Margin="0,0,0,10"/>

        <TextBlock Text="Выполнено:" Margin="0,10,0,5"/>
        <TextBox x:Name="ValueTextBox" Text="1"/>

        <TextBlock Text="Заметка (необязательно):" Margin="0,10,0,5"/>
        <TextBox x:Name="NoteTextBox" Height="60" TextWrapping="Wrap"/>

        <Button Content="Сохранить" Click="SaveButton_Click" Margin="0,20" Padding="10,5"/>
    </StackPanel>
</Window>