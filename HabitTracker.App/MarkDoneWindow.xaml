<Window x:Class="HabitTracker.App.MarkDoneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отметить выполнение" Height="320" Width="400"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource ForegroundBrush}">
    <StackPanel Margin="20">
        <TextBlock Text="Привычка:" FontWeight="Bold" Foreground="{StaticResource ForegroundBrush}"/>
        <TextBlock x:Name="HabitNameText" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,10"/>

        <TextBlock Text="Выполнено:" Foreground="{StaticResource ForegroundBrush}" Margin="0,10,0,5"/>
        <TextBox x:Name="ValueTextBox" Background="#3A3A3A" Foreground="White" BorderThickness="0" Padding="5" Text="1"/>

        <TextBlock Text="Заметка (необязательно):" Foreground="{StaticResource ForegroundBrush}" Margin="0,10,0,5"/>
        <TextBox x:Name="NoteTextBox" Background="#3A3A3A" Foreground="White" BorderThickness="0" Padding="5" Height="60" TextWrapping="Wrap"/>

        <Button Content="Сохранить" Click="SaveButton_Click" Background="{StaticResource AccentBrush}" Foreground="White" Margin="0,20" Padding="10,5" Height="35"/>
    </StackPanel>
</Window>