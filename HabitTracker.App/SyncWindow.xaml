<Window x:Class="HabitTracker.App.SyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Синхронизация с сервером" Height="400" Width="550">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Привычки на сервере:" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" x:Name="HabitsDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Цель" Binding="{Binding TargetValue}" Width="70"/>
                <DataGridTextColumn Header="Ед. изм." Binding="{Binding Unit}" Width="80"/>
                <DataGridCheckBoxColumn Header="Активна" Binding="{Binding IsActive}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="Закрыть" Click="CloseButton_Click" HorizontalAlignment="Right" Padding="20,5" Margin="0,10,0,0"/>
    </Grid>
</Window>