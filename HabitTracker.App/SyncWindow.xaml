<Window x:Class="HabitTracker.App.SyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Синхронизация" Height="260" Width="400"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource ForegroundBrush}">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Выберите направление синхронизации:" FontSize="14" Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,20"/>
        <Button Content="Загрузить с сервера (заменить локальные данные)" Click="Download_Click" Background="#3A3A3A" Foreground="White" Height="30" Margin="0,5"/>
        <Button Content="Отправить на сервер (заменить серверные данные)" Click="Upload_Click" Background="#3A3A3A" Foreground="White" Height="30" Margin="0,5"/>
        <Button Content="Отмена" Click="Cancel_Click" Background="#3A3A3A" Foreground="White" Height="30" Margin="0,20"/>
    </StackPanel>
</Window>